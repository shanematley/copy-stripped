{
	"name": "copy-stripped",
	"version": "1.0.2",
	"description": "Obsidian plugin to copy text with selected Markdown enrichments stripped.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "node test-strip.mjs",
		"preversion": "npm run build && npm test",
		"version": "node version-bump.mjs && git add manifest.json versions.json CHANGELOG.md",
		"postversion": "node release-instructions.mjs"
	},
	"keywords": [
		"obsidian",
		"plugin"
	],
	"author": "Shane Matley",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.20.0",
		"obsidian": "latest",
		"tslib": "^2.6.2",
		"typescript": "^5.4.0"
	}
}
